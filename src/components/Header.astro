---
---
<header class="sticky top-0 z-50 bg-background-light/90 dark:bg-background-dark/90 backdrop-blur-md border-b border-primary/10 px-6 lg:px-20 py-4">
  <div class="max-w-7xl mx-auto flex items-center justify-between gap-8">
    <!-- Logo & AI Search -->
    <div class="flex items-center gap-12">
      <a href="/" class="flex items-center gap-2 text-slate-900 dark:text-slate-100">
        <span class="material-symbols-outlined text-primary text-3xl">grid_view</span>
        <h1 class="font-display text-2xl font-bold tracking-tight">Decomaket</h1>
      </a>
      <div class="hidden md:flex items-center bg-white dark:bg-slate-800 border border-primary/20 rounded-lg px-3 py-1.5 w-80">
        <span class="material-symbols-outlined text-slate-400">search</span>
        <input class="bg-transparent border-none focus:ring-0 text-sm w-full placeholder:text-slate-400" placeholder="Buscar muebles..." type="text"/>
        <button class="flex items-center gap-1 bg-primary/10 hover:bg-primary/20 text-primary px-2 py-1 rounded transition-colors" title="AI Visual Search">
          <span class="material-symbols-outlined text-lg">linked_camera</span>
          <span class="text-[10px] font-bold uppercase tracking-wider">AI</span>
        </button>
      </div>
    </div>
    <!-- Main Categories -->
    <nav class="hidden lg:flex items-center gap-8 font-medium text-sm">
      <a class="hover:text-primary transition-colors" href="/category/asientos-premium">Sofás</a>
      <a class="hover:text-primary transition-colors" href="/category/iluminacion">Lighting</a>
      <a class="hover:text-primary transition-colors" href="/category/decoracion">Sala</a>
      <a class="hover:text-primary transition-colors" href="/collections">Colecciones</a>
    </nav>
    <!-- User Actions -->
    <div class="flex items-center gap-4">
      <button class="p-2 hover:bg-primary/10 rounded-full transition-colors">
        <span class="material-symbols-outlined">person</span>
      </button>
      <a href="/checkout" class="p-2 hover:bg-primary/10 rounded-full transition-colors relative">
        <span class="material-symbols-outlined">shopping_bag</span>
        <span class="cart-badge absolute top-1 right-1 bg-primary text-[10px] font-bold px-1.5 rounded-full" style="display: none;">0</span>
      </a>
      <button class="lg:hidden p-2 mobile-menu-btn">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
  <!-- Mobile Menu -->
  <div class="mobile-menu hidden lg:hidden mt-4 border-t border-primary/10 pt-4">
    <nav class="flex flex-col gap-4 font-medium text-sm">
      <a class="hover:text-primary transition-colors" href="/category/asientos-premium">Sofás</a>
      <a class="hover:text-primary transition-colors" href="/category/iluminacion">Lighting</a>
      <a class="hover:text-primary transition-colors" href="/category/decoracion">Sala</a>
      <a class="hover:text-primary transition-colors" href="/collections">Colecciones</a>
    </nav>
  </div>
</header>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pago Seguro">
    <main class="flex flex-1 justify-center py-8 px-4 md:px-0">
        <div class="layout-content-container flex flex-col md:flex-row max-w-[1100px] flex-1 gap-8 w-full">
            <!-- Checkout Steps (Left Column) -->
            <div class="flex flex-col flex-1 gap-4">
                <h1 class="text-3xl font-black mb-4 px-2 italic font-display">Pago</h1>
                
                <!-- Step 1: Shipping Address -->
                <details class="group border border-primary/20 bg-white dark:bg-slate-900/50 rounded-lg overflow-hidden transition-all" open>
                    <summary class="flex cursor-pointer items-center justify-between p-5 hover:bg-slate-50 dark:hover:bg-slate-800/50 list-none">
                        <div class="flex items-center gap-4">
                            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary text-slate-900 font-bold text-sm">1</span>
                            <h3 class="text-lg font-bold font-display">Dirección de Envío</h3>
                        </div>
                        <span class="material-symbols-outlined group-open:rotate-180 transition-transform text-slate-400">expand_more</span>
                    </summary>
                    <div class="p-6 pt-0 border-t border-primary/10">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div class="flex flex-col gap-1 md:col-span-2">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Correo Electrónico</label>
                                <input class="form-input rounded border-primary/30 bg-transparent focus:border-primary focus:ring-primary h-12 px-4" placeholder="you@example.com" type="email"/>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Nombre</label>
                                <input class="form-input rounded border-primary/30 bg-transparent focus:border-primary focus:ring-primary h-12 px-4" placeholder="John" type="text"/>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Apellido</label>
                                <input class="form-input rounded border-primary/30 bg-transparent focus:border-primary focus:ring-primary h-12 px-4" placeholder="Doe" type="text"/>
                            </div>
                            <div class="flex flex-col gap-1 md:col-span-2">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Calle y número</label>
                                <input class="form-input rounded border-primary/30 bg-transparent focus:border-primary focus:ring-primary h-12 px-4" placeholder="Nombre de calle y número" type="text"/>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Ciudad</label>
                                <input class="form-input rounded border-primary/30 bg-transparent focus:border-primary focus:ring-primary h-12 px-4" type="text"/>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Código Postal</label>
                                <input class="form-input rounded border-primary/30 bg-transparent focus:border-primary focus:ring-primary h-12 px-4" type="text"/>
                            </div>
                        </div>
                        <div class="mt-6">
                            <button class="w-full md:w-auto px-12 py-4 bg-primary text-slate-900 font-bold rounded-lg hover:brightness-110 transition-all uppercase text-xs tracking-[0.2em] shadow-lg">CONTINUAR AL PAGO</button>
                        </div>
                    </div>
                </details>

                <!-- Step 2: Payment Method -->
                <details class="group border border-primary/20 bg-white dark:bg-slate-900/50 rounded-lg overflow-hidden transition-all">
                    <summary class="flex cursor-pointer items-center justify-between p-5 hover:bg-slate-50 dark:hover:bg-slate-800/50 list-none">
                        <div class="flex items-center gap-4">
                            <span class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-primary/40 text-slate-400 font-bold text-sm">2</span>
                            <h3 class="text-lg font-bold font-display">Método de Pago</h3>
                        </div>
                        <span class="material-symbols-outlined group-open:rotate-180 transition-transform text-slate-400">expand_more</span>
                    </summary>
                    <div class="p-6 pt-0 border-t border-primary/10">
                        <div class="flex flex-col gap-4 mt-4">
                            <div class="flex gap-4 p-4 border border-primary rounded-lg bg-primary/5">
                                <span class="material-symbols-outlined text-primary">credit_card</span>
                                <span class="font-bold">Tarjeta de Crédito / Débito</span>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Número de Tarjeta</label>
                                <input class="form-input w-full rounded border-primary/30 bg-transparent focus:ring-primary h-12 px-4" placeholder="0000 0000 0000 0000" type="text"/>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1">
                                    <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Expiración</label>
                                    <input class="form-input rounded border-primary/30 bg-transparent focus:border-primary focus:ring-primary h-12 px-4" placeholder="MM / YY" type="text"/>
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-xs font-bold uppercase tracking-widest text-slate-500">CVV</label>
                                    <input class="form-input rounded border-primary/30 bg-transparent focus:border-primary focus:ring-primary h-12 px-4" placeholder="123" type="text"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </details>

                <!-- Step 3: Review Order -->
                <details class="group border border-primary/20 bg-white dark:bg-slate-900/50 rounded-lg overflow-hidden transition-all">
                    <summary class="flex cursor-pointer items-center justify-between p-5 hover:bg-slate-50 dark:hover:bg-slate-800/50 list-none">
                        <div class="flex items-center gap-4">
                            <span class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-primary/40 text-slate-400 font-bold text-sm">3</span>
                            <h3 class="text-lg font-bold font-display">Revisar y Confirmar Pedido</h3>
                        </div>
                        <span class="material-symbols-outlined group-open:rotate-180 transition-transform text-slate-400">expand_more</span>
                    </summary>
                    <div class="p-6 pt-0 border-t border-primary/10">
                        <div class="flex flex-col gap-4 mt-4">
                            <p class="text-xs text-slate-500 leading-relaxed uppercase tracking-wider font-bold">Resumen de Artículos</p>
                            <div id="checkout-items-list" class="space-y-4 max-h-60 overflow-y-auto pr-2">
                                <!-- Dynamic Items -->
                            </div>
                            <div class="mt-8 pt-4 border-t border-primary/10">
                                <p class="text-xs text-slate-500 mb-6 italic">Al hacer clic en 'Confirmar Pedido', aceptas los Términos de Servicio y la Política de Privacidad de Decomaket.</p>
                                <button id="complete-btn" class="w-full py-5 bg-primary text-slate-900 font-black rounded-lg hover:brightness-110 transition-all uppercase tracking-[0.2em] text-lg shadow-xl active:scale-95">
                                    Confirmar Pedido — <span class="total-price-display">$0.00</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </details>
            </div>

            <!-- Summary Sidebar (Right Column) -->
            <aside class="w-full md:w-[360px] flex flex-col gap-6">
                <div class="bg-white dark:bg-slate-900/50 border border-primary/20 rounded-lg p-8 sticky top-24 shadow-sm">
                    <h3 class="text-xl font-bold mb-6 border-b border-primary/10 pb-4 font-display italic">Resumen del Pedido</h3>
                    
                    <div id="checkout-sidebar-items" class="flex flex-col gap-4">
                        <!-- Dynamic Sidebar Items -->
                    </div>

                    <div class="mt-8 pt-6 border-t border-primary/20 flex flex-col gap-3">
                        <div class="flex justify-between text-sm uppercase tracking-widest font-bold text-slate-400">
                            <span>Subtotal</span>
                            <span id="subtotal">$0.00</span>
                        </div>
                        <div class="flex justify-between text-sm uppercase tracking-widest font-bold text-slate-400">
                            <span>Impuestos (21%)</span>
                            <span id="tax">$0.00</span>
                        </div>
                        <div class="flex justify-between text-xs font-bold uppercase tracking-widest">
                            <span class="text-slate-500">Envío</span>
                            <span class="text-green-600 font-bold bg-green-100 dark:bg-green-900/30 px-2 py-0.5 rounded">GRATIS</span>
                        </div>
                        <div class="flex justify-between items-center mt-4 pt-4 border-t border-primary/10">
                            <span class="text-lg font-bold font-display">Total</span>
                            <span id="total" class="text-2xl font-black text-primary">$0.00</span>
                        </div>
                    </div>

                    <div class="mt-8 p-4 bg-primary/5 rounded border border-primary/10 flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary text-xl">verified_user</span>
                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-800 dark:text-white">GARANTÍA DECOMAKET</p>
                            <p class="text-[10px] text-slate-500 mt-1">Política de devolución de 30 días sin preguntas y protección premium incluida.</p>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </main>

    <script>
        function renderCheckout() {
            const list = document.getElementById('checkout-items-list');
            const sidebar = document.getElementById('checkout-sidebar-items');
            if (!list || !sidebar) return;
            
            const cart = JSON.parse(localStorage.getItem('cart') || '[]');
            
            if (cart.length === 0) {
                // Handle empty cart
                document.querySelector('main').innerHTML = `
                    <div class="max-w-7xl mx-auto px-4 py-24 text-center">
                        <span class="material-symbols-outlined text-primary text-6xl mb-6">shopping_bag</span>
                        <h2 class="text-4xl font-display font-bold mb-4">Tu carrito está vacío</h2>
                        <p class="text-slate-500 mb-8">Parece que aún no has añadido ninguna pieza a tu colección.</p>
                        <a href="/" class="bg-primary text-slate-900 px-10 py-4 rounded font-bold uppercase tracking-widest text-xs hover:brightness-110 transition-all">Seguir comprando</a>
                    </div>
                `;
                return;
            }

            // Render detailed list in Step 3
            list.innerHTML = cart.map((item, i) => `
                <div class="flex gap-4 py-4 border-b border-primary/5 items-center">
                    <img src="${item.product.image}" class="w-16 h-20 object-cover rounded-lg">
                    <div class="flex-1">
                        <h3 class="font-bold text-sm text-slate-800 dark:text-white">${item.product.name}</h3>
                        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">${item.color || ''} / ${item.material || ''}</p>
                        <div class="flex items-center mt-2 gap-4">
                            <div class="flex items-center border border-primary/30 rounded px-2 bg-white dark:bg-slate-800">
                                <button class="quantity-btn p-1 text-primary hover:text-primary/70" data-index="${i}" data-val="-1">remove</button>
                                <span class="px-3 text-xs font-bold">${item.quantity}</span>
                                <button class="quantity-btn p-1 text-primary hover:text-primary/70" data-index="${i}" data-val="1">add</button>
                            </div>
                            <button class="remove-btn text-[10px] font-bold text-red-500 uppercase tracking-widest hover:underline" data-index="${i}">Eliminar</button>
                        </div>
                    </div>
                    <p class="font-bold text-sm text-primary">$${(item.product.price * item.quantity).toFixed(2)}</p>
                </div>
            `).join('');

            // Render sidebar summary items
            sidebar.innerHTML = cart.map((item) => `
                <div class="flex gap-4">
                    <div class="h-16 w-12 bg-slate-100 dark:bg-slate-800 rounded flex-shrink-0 overflow-hidden">
                        <img src="${item.product.image}" class="h-full w-full object-cover">
                    </div>
                    <div class="flex flex-col justify-between flex-1">
                        <div>
                            <p class="font-bold text-xs truncate max-w-[150px]">${item.product.name}</p>
                            <p class="text-[9px] text-slate-500 uppercase font-bold tracking-widest">${item.color || ''}</p>
                        </div>
                        <div class="flex justify-between items-center">
                            <p class="text-[10px] font-bold text-slate-400">Cant: ${item.quantity}</p>
                            <p class="font-bold text-xs">$${(item.product.price * item.quantity).toFixed(2)}</p>
                        </div>
                    </div>
                </div>
            `).join('');

            const subtotal = cart.reduce((sum, item) => sum + (item.product.price * item.quantity), 0);
            const tax = subtotal * 0.21;
            const total = subtotal + tax;

            document.getElementById('subtotal').textContent = `$${subtotal.toLocaleString()}`;
            document.getElementById('tax').textContent = `$${tax.toLocaleString()}`;
            document.getElementById('total').textContent = `$${total.toLocaleString()}`;
            document.querySelectorAll('.total-price-display').forEach(el => el.textContent = `$${total.toLocaleString()}`);

            // Event listeners for quantity buttons
            document.querySelectorAll('.quantity-btn').forEach(btn => btn.addEventListener('click', e => {
                const idx = parseInt(btn.dataset.index);
                const val = parseInt(btn.dataset.val);
                const currentCart = JSON.parse(localStorage.getItem('cart'));
                currentCart[idx].quantity = Math.max(1, currentCart[idx].quantity + val);
                localStorage.setItem('cart', JSON.stringify(currentCart));
                renderCheckout();
                window.dispatchEvent(new CustomEvent('cart-updated'));
            }));

            document.querySelectorAll('.remove-btn').forEach(btn => btn.addEventListener('click', e => {
                const idx = parseInt(btn.dataset.index);
                const currentCart = JSON.parse(localStorage.getItem('cart'));
                currentCart.splice(idx, 1);
                localStorage.setItem('cart', JSON.stringify(currentCart));
                renderCheckout();
                window.dispatchEvent(new CustomEvent('cart-updated'));
            }));
        }

        document.getElementById('complete-btn')?.addEventListener('click', () => {
            alert('¡Pedido realizado con éxito! Gracias por elegir Decomaket.');
            localStorage.setItem('cart', '[]');
            window.location.href = '/';
        });

        // Init
        document.addEventListener('DOMContentLoaded', renderCheckout);
        window.addEventListener('cart-updated', renderCheckout);
    </script>
</Layout>

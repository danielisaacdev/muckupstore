---
import Layout from '../layouts/Layout.astro';
import { collectionsData } from '../data/products';
---

<Layout title="Colecciones">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full">
        <!-- Header -->
        <div class="text-center mb-24 max-w-3xl mx-auto">
            <span class="text-primary font-bold tracking-[0.3em] text-[10px] uppercase mb-4 block">Atelier Design Studio</span>
            <h1 class="text-5xl md:text-7xl font-display font-black mb-6 tracking-tighter italic">Nuestras Colecciones</h1>
            <div class="h-1 w-24 bg-primary mx-auto mb-8"></div>
            <p class="text-slate-500 font-sans leading-relaxed text-lg">
                Explora nuestras series curadas, donde la arquitectura se encuentra con la comodidad. Cada colección es un estudio exhaustivo de forma, material y función.
            </p>
        </div>

        <!-- Collections Grid/List -->
        <div class="space-y-40">
            {collectionsData.map((c, i) => (
                <div class={`flex flex-col lg:flex-row gap-16 items-center ${i % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
                    <div class="w-full lg:w-1/2 relative group">
                        <div class="absolute -inset-4 bg-primary/5 rounded-[2rem] -rotate-2 group-hover:rotate-0 transition-transform duration-700"></div>
                        <div class="relative overflow-hidden rounded-2xl shadow-2xl border border-primary/10">
                            <img src={c.image} class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-[2s]" />
                        </div>
                    </div>
                    <div class="w-full lg:w-1/2 flex flex-col items-start px-4">
                        <span class="text-primary font-bold text-4xl mb-6 font-display opacity-20 italic">0{i + 1}</span>
                        <h2 class="text-4xl font-display font-bold mb-6 text-slate-900 dark:text-white tracking-tight">{c.title}</h2>
                        <div class="w-12 h-0.5 bg-primary/30 mb-8"></div>
                        <p class="text-slate-600 dark:text-slate-400 mb-10 text-lg leading-relaxed font-sans max-w-lg">{c.description}</p>
                        <a href={c.link} class="group inline-flex items-center gap-4 bg-primary text-slate-900 px-8 py-4 rounded-full font-bold uppercase tracking-widest text-[10px] hover:shadow-xl hover:shadow-primary/20 transition-all active:scale-95">
                            Explorar colección 
                            <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
                        </a>
                    </div>
                </div>
            ))}
        </div>

        <!-- CTA Section -->
        <div class="mt-40 bg-slate-900 dark:bg-black rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden">
            <div class="absolute inset-0 bg-primary/5 pointer-events-none"></div>
            <h2 class="text-4xl font-display text-white mb-8 italic">¿Buscas algo a medida?</h2>
            <p class="text-slate-400 max-w-xl mx-auto mb-12 font-sans">Nuestro equipo de diseño puede ayudarte a crear la pieza perfecta para tu espacio único.</p>
            <button class="border border-primary text-primary px-12 py-4 rounded-full font-bold uppercase tracking-widest text-xs hover:bg-primary hover:text-slate-900 transition-all">Habla con un consultor</button>
        </div>
    </div>
</Layout>
